</div>

<script>
let allResults = [];

function setStatus(msg, type) {
  const el = document.getElementById('status');
  el.textContent = msg;
  el.className = 'status' + (type ? ' ' + type : '');
}

function setProgress(pct) {
  document.getElementById('progress').style.width = pct + '%';
}

async function extractKeywordsAI(script, maxKw, apiKey) {
  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-api-key': apiKey,
      'anthropic-version': '2023-06-01',
      'anthropic-dangerous-direct-browser-access': 'true'
    },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 800,
      messages: [{
        role: 'user',
        content: `You are a video producer for a faceless YouTube channel. Analyze this script and extract ${maxKw} specific visual search keywords to find matching stock footage and photos.

Rules:
- Each keyword must describe something a camera would actually capture on screen
- 2–4 words max per keyword
- Specific and vivid — not "people" but "crowd city plaza"
- Cover different visual moments/scenes across the script
- Optimized for stock footage search engines

Return ONLY a valid JSON array of strings. No explanation, no markdown, no backticks.
Example: ["ancient ruins aerial", "scientist laboratory night", "stock market trading floor"]

Script:
${script}`
      }]
    })
  });
  if (!res.ok) throw new Error(`Claude API error: ${res.status}`);
  const data = await res.json();
  return JSON.parse(data.content[0].text.trim());
}

function extractKeywordsFallback(script, maxKw) {
  // Smart fallback: extract noun phrases and visual scene descriptors
  const sentences = script.split(/[.!?\n]+/).filter(s => s.trim().length > 20);
  const stopwords = new Set(['the','a','an','and','or','but','in','on','at','to','for','of','with','by','from','as','is','was','are','were','be','been','being','have','has','had','do','does','did','will','would','could','should','may','might','that','this','these','those','their','there','then','when','what','which','who','how','just','also','more','very','still','even','back','way','first','last','long','little','own','other','old','right','big','high','small','large','next','early','young','important','few','public','bad','same','able']);
  const keywords = new Set();
  const patterns = [
    /\b(\w+ (?:city|street|crowd|building|court|police|night|day|market|office|lab|forest|ocean|mountain|sky|fire|water|war|protest|stage|arena|hospital|school|prison|bank|church|government|military|factory|farm|highway|bridge|airport|museum|library))\b/gi,
    /\b((?:ancient|modern|dark|bright|crowded|empty|burning|frozen|massive|tiny|secret|hidden|underwater|aerial|dramatic) \w+)\b/gi,
    /\b(\w+ (?:gathering|explosion|collapse|ceremony|battle|celebration|funeral|march|debate|experiment|discovery))\b/gi
  ];
  for (const pat of patterns) {
    let m;
    while ((m = pat.exec(script)) !== null) {
      const kw = m[1].toLowerCase().trim();
      if (kw.split(' ').every(w => !stopwords.has(w))) keywords.add(kw);
    }
  }
  // Also grab 2-word combos of nouns from sentences
  for (const s of sentences.slice(0, 10)) {
    const words = s.split(/\s+/).filter(w => w.length > 4 && !stopwords.has(w.toLowerCase()) && /^[a-zA-Z]+$/.test(w));
    for (let i = 0; i < words.length - 1; i++) {
      keywords.add(`${words[i].toLowerCase()} ${words[i+1].toLowerCase()}`);
    }
  }
  return [...keywords].slice(0, maxKw);
}

async function searchPexelsVideos(kw, key, n) {
  const r = await fetch(`https://api.pexels.com/videos/search?query=${encodeURIComponent(kw)}&per_page=${n}&orientation=landscape`, { headers: { Authorization: key } });
  if (!r.ok) return [];
  const d = await r.json();
  return (d.videos || []).map(v => {
    const files = (v.video_files || []).sort((a,b) => (b.width||0)-(a.width||0));
    return { keyword:kw, type:'Video', source:'Pexels', title:`Pexels #${v.id}`, photographer:v.user?.name||'', duration:v.duration?`${v.duration}s`:'—', resolution:`${v.width}x${v.height}`, license:'Free – Pexels License', preview:v.image||'', download:files[0]?.link||'', page:v.url||'' };
  });
}

async function searchPexelsPhotos(kw, key, n) {
  const r = await fetch(`https://api.pexels.com/v1/search?query=${encodeURIComponent(kw)}&per_page=${n}&orientation=landscape`, { headers: { Authorization: key } });
  if (!r.ok) return [];
  const d = await r.json();
  return (d.photos || []).map(p => ({ keyword:kw, type:'Photo', source:'Pexels', title:p.alt||`Pexels #${p.id}`, photographer:p.photographer||'', duration:'—', resolution:`${p.width}x${p.height}`, license:'Free – Pexels License', preview:p.src?.medium||'', download:p.src?.original||'', page:p.url||'' }));
}

async function searchPixabayVideos(kw, key, n) {
  const r = await fetch(`https://pixabay.com/api/videos/?key=${key}&q=${encodeURIComponent(kw)}&per_page=${n}&safesearch=true`);
  if (!r.ok) return [];
  const d = await r.json();
  return (d.hits || []).map(v => {
    const best = v.videos?.large || v.videos?.medium || {};
    return { keyword:kw, type:'Video', source:'Pixabay', title:`Pixabay #${v.id}`, photographer:v.user||'', duration:v.duration?`${v.duration}s`:'—', resolution:`${best.width||''}x${best.height||''}`, license:'Free – Pixabay License', preview:`https://i.vimeocdn.com/video/${v.picture_id}_295x166.jpg`, download:best.url||'', page:v.pageURL||'' };
  });
}

async function searchPixabayPhotos(kw, key, n) {
  const r = await fetch(`https://pixabay.com/api/?key=${key}&q=${encodeURIComponent(kw)}&per_page=${n}&safesearch=true&orientation=horizontal`);
  if (!r.ok) return [];
  const d = await r.json();
  return (d.hits || []).map(p => ({ keyword:kw, type:'Photo', source:'Pixabay', title:`Pixabay #${p.id}`, photographer:p.user||'', duration:'—', resolution:`${p.imageWidth}x${p.imageHeight}`, license:'Free – Pixabay License', preview:p.previewURL||'', download:p.largeImageURL||'', page:p.pageURL||'' }));
}

function renderKeywords(kws) {
  document.getElementById('kw-section').style.display = 'block';
  document.getElementById('kw-pills').innerHTML = kws.map(k => `<span class="kw-pill">${k}</span>`).join('');
}

function renderStats(results) {
  const videos = results.filter(r => r.type==='Video').length;
  const photos = results.filter(r => r.type==='Photo').length;
  const pexels = results.filter(r => r.source==='Pexels').length;
  const pixabay = results.filter(r => r.source==='Pixabay').length;
  const el = document.getElementById('stats');
  el.style.display = 'grid';
  el.className = 'stats fade-in';
  el.innerHTML = `
    <div class="stat"><div class="stat-n">${results.length}</div><div class="stat-l">Total Results</div></div>
    <div class="stat"><div class="stat-n">${videos}</div><div class="stat-l">Videos</div></div>
    <div class="stat"><div class="stat-n">${photos}</div><div class="stat-l">Photos</div></div>
    <div class="stat"><div class="stat-n">${pexels}/${pixabay}</div><div class="stat-l">Pexels / Pixabay</div></div>
  `;
}

function renderTable(results) {
  const incVideos = document.getElementById('inc-videos').checked;
  const incPhotos = document.getElementById('inc-photos').checked;
  const filtered = results.filter(r => (r.type==='Video'&&incVideos)||(r.type==='Photo'&&incPhotos));
  if (!filtered.length) return;
  const rows = filtered.map(r => `
    <tr>
      <td><img class="thumb" src="${r.preview}" alt="" onerror="this.style.display='none'" /></td>
      <td>${r.keyword}</td>
      <td><span class="badge ${r.type==='Video'?'b-video':'b-photo'}">${r.type}</span></td>
      <td><span class="badge ${r.source==='Pexels'?'b-px':'b-pb'}">${r.source}</span></td>
      <td style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${r.title}</td>
      <td style="color:#888">${r.photographer}</td>
      <td style="color:#888">${r.duration}</td>
      <td style="color:#888">${r.resolution}</td>
      <td>${r.page ? `<a href="${r.page}" target="_blank">view ↗</a>` : '—'}</td>
      <td>${r.download ? `<a href="${r.download}" target="_blank">download ↗</a>` : '—'}</td>
    </tr>
  `).join('');
  document.getElementById('table-wrap').innerHTML = `
    <div class="table-wrap fade-in">
      <table>
        <thead><tr>
          <th>preview</th><th>keyword</th><th>type</th><th>source</th>
          <th>title</th><th>creator</th><th>duration</th><th>resolution</th>
          <th>page</th><th>download</th>
        </tr></thead>
        <tbody>${rows}</tbody>
      </table>
    </div>
  `;
}

function buildCSV(results) {
  const headers = ['keyword','type','source','title','photographer','duration','resolution','license','preview_url','download_url','page_url'];
  const rows = results.map(r =>
    [r.keyword,r.type,r.source,r.title,r.photographer,r.duration,r.resolution,r.license,r.preview,r.download,r.page]
    .map(v => `"${(v||'').replace(/"/g,'""')}"`)
    .join(',')
  );
  return [headers.join(','), ...rows].join('\n');
}

function buildSummary(results, keywords) {
  const videos = results.filter(r=>r.type==='Video');
  const photos = results.filter(r=>r.type==='Photo');
  const pexels = results.filter(r=>r.source==='Pexels');
  const pixabay = results.filter(r=>r.source==='Pixabay');
  const kwGroups = {};
  for (const r of results) {
    if (!kwGroups[r.keyword]) kwGroups[r.keyword] = [];
    kwGroups[r.keyword].push(r);
  }
  const date = new Date().toLocaleString();
  let txt = `THE Finder — STOCK FOOTAGE SCRAPE REPORT\n`;
  txt += `Generated: ${date}\n`;
  txt += `${'='.repeat(50)}\n\n`;
  txt += `SUMMARY\n-------\n`;
  txt += `Total results : ${results.length}\n`;
  txt += `Videos        : ${videos.length}\n`;
  txt += `Photos        : ${photos.length}\n`;
  txt += `Pexels        : ${pexels.length}\n`;
  txt += `Pixabay       : ${pixabay.length}\n\n`;
  txt += `KEYWORDS USED (${keywords.length})\n${'─'.repeat(30)}\n`;
  keywords.forEach((kw,i) => {
    const g = kwGroups[kw] || [];
    txt += `${String(i+1).padStart(2,'0')}. ${kw} — ${g.length} results\n`;
  });
  txt += `\nRESULTS BY KEYWORD\n${'─'.repeat(30)}\n`;
  for (const [kw, items] of Object.entries(kwGroups)) {
    txt += `\n[ ${kw.toUpperCase()} ]\n`;
    items.forEach(r => {
      txt += `  ${r.type} | ${r.source} | ${r.title}\n`;
      txt += `  Page    : ${r.page}\n`;
      txt += `  Download: ${r.download}\n`;
    });
  }
  return txt;
}

async function downloadZip() {
  if (!allResults.length) return;
  const btn = document.getElementById('dl-btn');
  btn.disabled = true;
  btn.textContent = 'Building ZIP...';

  const JSZip = window.JSZip;
  const zip = new JSZip();
  const folder = zip.folder('Finder_stock_footage');

  // CSV
  folder.file('results.csv', buildCSV(allResults));

  // JSON
  folder.file('results.json', JSON.stringify(allResults, null, 2));

  // Summary txt
  const kws = [...new Set(allResults.map(r=>r.keyword))];
  folder.file('summary.txt', buildSummary(allResults, kws));

  // Per-keyword CSVs in subfolder
  const byKw = zip.folder('Finder_stock_footage/by_keyword');
  const groups = {};
  for (const r of allResults) {
    if (!groups[r.keyword]) groups[r.keyword] = [];
    groups[r.keyword].push(r);
  }
  for (const [kw, items] of Object.entries(groups)) {
    const safeName = kw.replace(/[^a-z0-9]+/gi,'_').toLowerCase();
    byKw.file(`${safeName}.csv`, buildCSV(items));
  }

  const blob = await zip.generateAsync({type:'blob', compression:'DEFLATE'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'Finder_stock_footage.zip';
  a.click();

  btn.disabled = false;
  btn.textContent = 'Download ZIP (CSV + JSON + Summary)';
}

async function runScraper() {
  const script = document.getElementById('script').value.trim();
  const pexelsKey = document.getElementById('pexels-key').value.trim();
  const pixabayKey = document.getElementById('pixabay-key').value.trim();
  const claudeKey = document.getElementById('claude-key').value.trim();
  const perKw = parseInt(document.getElementById('per-kw').value) || 3;
  const maxKw = parseInt(document.getElementById('max-kw').value) || 10;
  const usePexels = document.getElementById('use-pexels').checked;
  const usePixabay = document.getElementById('use-pixabay').checked;

  if (!script) { setStatus('Please paste your script first.', 'err'); return; }
  if (!pexelsKey && !pixabayKey) { setStatus('At least one API key is required.', 'err'); return; }

  const btn = document.getElementById('run-btn');
  btn.disabled = true;
  document.getElementById('kw-section').style.display = 'none';
  document.getElementById('stats').style.display = 'none';
  document.getElementById('table-wrap').innerHTML = '';
  document.getElementById('dl-wrap').innerHTML = '';
  allResults = [];
  setProgress(0);

  try {
    let keywords;
    if (claudeKey) {
      setStatus('Analyzing script with Claude AI...');
      keywords = await extractKeywordsAI(script, maxKw, claudeKey);
    } else {
      setStatus('Extracting visual keywords from script...');
      keywords = extractKeywordsFallback(script, maxKw);
    }

    renderKeywords(keywords);
    setProgress(10);

    for (let i = 0; i < keywords.length; i++) {
      const kw = keywords[i];
      setStatus(`Searching (${i+1}/${keywords.length}): "${kw}"...`);
      const tasks = [];
      if (usePexels && pexelsKey) {
        tasks.push(searchPexelsVideos(kw, pexelsKey, perKw).catch(()=>[]));
        tasks.push(searchPexelsPhotos(kw, pexelsKey, perKw).catch(()=>[]));
      }
      if (usePixabay && pixabayKey) {
        tasks.push(searchPixabayVideos(kw, pixabayKey, perKw).catch(()=>[]));
        tasks.push(searchPixabayPhotos(kw, pixabayKey, perKw).catch(()=>[]));
      }
      const batches = await Promise.all(tasks);
      batches.forEach(b => allResults.push(...b));
      setProgress(10 + Math.round(((i+1)/keywords.length)*85));
    }

    renderStats(allResults);
    renderTable(allResults);
    setProgress(100);
    setStatus(`Done — ${allResults.length} results found across ${keywords.length} keywords.`, 'ok');

    document.getElementById('dl-wrap').innerHTML = `<button class="btn-dl" id="dl-btn" onclick="downloadZip()">Download ZIP (CSV + JSON + Summary)</button>`;
  } catch(e) {
    setStatus('Error: ' + e.message, 'err');
    console.error(e);
  }
  btn.disabled = false;
}
</script>
