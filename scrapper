<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>The Finder — Stock Footage Scraper</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
<style>
  :root {
    --gold: #C9A84C;
    --gold-dim: #8a6e2f;
    --bg: #0a0a0a;
    --surface: #111111;
    --surface2: #181818;
    --border: #2a2a2a;
    --border-gold: rgba(201,168,76,0.25);
    --text: #e8e2d6;
    --text-muted: #6b6560;
    --text-dim: #4a4540;
    --red: #c0392b;
    --green: #27ae60;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    min-height: 100vh;
    padding: 0;
  }

  /* Grid background */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image:
      linear-gradient(rgba(201,168,76,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(201,168,76,0.03) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    z-index: 0;
  }

  .wrap { position: relative; z-index: 1; max-width: 900px; margin: 0 auto; padding: 48px 24px 80px; }

  /* Header */
  .header { margin-bottom: 48px; }
  .logo-row { display: flex; align-items: center; gap: 14px; margin-bottom: 8px; }
  .logo-icon {
    width: 36px; height: 36px; border: 1px solid var(--gold);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif; font-size: 18px; color: var(--gold);
    transform: rotate(45deg);
  }
  .logo-icon span { transform: rotate(-45deg); display: block; }
  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 32px; font-weight: 600; letter-spacing: 0.02em;
    color: var(--text);
  }
  h1 em { color: var(--gold); font-style: italic; }
  .tagline { font-size: 13px; color: var(--text-muted); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 4px; }

  /* Sections */
  .section { margin-bottom: 28px; }
  .section-label {
    font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--gold-dim); margin-bottom: 10px; display: flex; align-items: center; gap: 8px;
  }
  .section-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  textarea {
    width: 100%; min-height: 180px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 4px; padding: 16px;
    font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 300;
    color: var(--text); line-height: 1.7; resize: vertical; outline: none;
    transition: border-color 0.2s;
  }
  textarea:focus { border-color: var(--border-gold); }
  textarea::placeholder { color: var(--text-dim); }

  .keys-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .options-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }

  .field label {
    display: block; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text-muted); margin-bottom: 6px;
  }
  .field input {
    width: 100%; background: var(--surface); border: 1px solid var(--border);
    border-radius: 4px; padding: 10px 12px;
    font-family: 'DM Mono', monospace; font-size: 12px; color: var(--text);
    outline: none; transition: border-color 0.2s;
  }
  .field input:focus { border-color: var(--border-gold); }

  /* Checkboxes */
  .check-row { display: flex; gap: 20px; flex-wrap: wrap; }
  .check-item { display: flex; align-items: center; gap: 8px; cursor: pointer; }
  .check-item input[type=checkbox] { appearance: none; width: 16px; height: 16px;
    border: 1px solid var(--border); background: var(--surface); border-radius: 2px;
    cursor: pointer; position: relative; transition: border-color 0.2s; }
  .check-item input[type=checkbox]:checked { border-color: var(--gold); background: var(--gold); }
  .check-item input[type=checkbox]:checked::after {
    content: ''; position: absolute; left: 4px; top: 1px;
    width: 5px; height: 9px; border: 2px solid #000;
    border-left: none; border-top: none; transform: rotate(45deg);
  }
  .check-item span { font-size: 13px; color: var(--text-muted); }

  /* Run button */
  .btn-run {
    width: 100%; padding: 14px;
    background: transparent; border: 1px solid var(--gold);
    color: var(--gold); font-family: 'DM Sans', sans-serif;
    font-size: 13px; font-weight: 500; letter-spacing: 0.12em;
    text-transform: uppercase; cursor: pointer; border-radius: 4px;
    transition: background 0.2s, color 0.2s;
    position: relative; overflow: hidden;
  }
  .btn-run:hover:not(:disabled) { background: var(--gold); color: #000; }
  .btn-run:disabled { opacity: 0.35; cursor: not-allowed; }

  /* Status */
  .status-wrap { margin-top: 20px; }
  .status {
    padding: 12px 16px; background: var(--surface);
    border-left: 2px solid var(--border-gold);
    font-size: 13px; color: var(--text-muted);
    font-family: 'DM Mono', monospace; line-height: 1.5;
    min-height: 42px;
  }
  .status.err { border-left-color: var(--red); color: #e57373; }
  .status.ok { border-left-color: var(--green); color: #81c784; }

  /* Progress bar */
  .progress-outer {
    height: 2px; background: var(--border); margin-top: 8px; border-radius: 1px; overflow: hidden;
  }
  .progress-inner {
    height: 100%; background: var(--gold); width: 0%;
    transition: width 0.4s ease; border-radius: 1px;
  }

  /* Keywords */
  .kw-section { margin-top: 24px; }
  .kw-pills { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
  .kw-pill {
    font-size: 11px; padding: 4px 12px; border-radius: 999px;
    border: 1px solid var(--border-gold); color: var(--gold);
    font-family: 'DM Mono', monospace; background: rgba(201,168,76,0.05);
  }

  /* Stats */
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-top: 24px; }
  .stat {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 4px; padding: 14px 16px;
  }
  .stat-n { font-size: 26px; font-weight: 500; color: var(--text); font-family: 'Cormorant Garamond', serif; }
  .stat-l { font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-top: 2px; }

  /* Table */
  .table-wrap { margin-top: 28px; overflow-x: auto; border: 1px solid var(--border); border-radius: 4px; }
  table { width: 100%; border-collapse: collapse; font-size: 12px; min-width: 700px; }
  thead { background: var(--surface2); }
  th {
    text-align: left; padding: 10px 12px;
    font-size: 10px; font-weight: 500; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--text-muted);
    border-bottom: 1px solid var(--border); white-space: nowrap;
  }
  td {
    padding: 9px 12px; border-bottom: 1px solid var(--border);
    color: var(--text); vertical-align: middle;
    font-family: 'DM Sans', sans-serif;
  }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--surface2); }

  .badge {
    display: inline-block; font-size: 10px; padding: 2px 8px;
    border-radius: 2px; font-weight: 500; letter-spacing: 0.05em;
    font-family: 'DM Mono', monospace;
  }
  .b-video { background: rgba(201,168,76,0.12); color: var(--gold); border: 1px solid rgba(201,168,76,0.2); }
  .b-photo { background: rgba(39,174,96,0.1); color: #81c784; border: 1px solid rgba(39,174,96,0.2); }
  .b-px { color: #90caf9; background: rgba(144,202,249,0.08); border: 1px solid rgba(144,202,249,0.15); }
  .b-pb { color: #ffcc80; background: rgba(255,204,128,0.08); border: 1px solid rgba(255,204,128,0.15); }

  a { color: var(--gold); text-decoration: none; font-size: 11px; }
  a:hover { text-decoration: underline; }

  /* Thumb preview */
  .thumb { width: 52px; height: 34px; object-fit: cover; border-radius: 2px; border: 1px solid var(--border); background: var(--surface2); display: block; }

  /* Download button */
  .btn-dl {
    margin-top: 20px; padding: 11px 28px;
    background: transparent; border: 1px solid var(--border);
    color: var(--text-muted); font-family: 'DM Sans', sans-serif;
    font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase;
    cursor: pointer; border-radius: 4px; transition: border-color 0.2s, color 0.2s;
  }
  .btn-dl:hover { border-color: var(--gold); color: var(--gold); }

  /* Fade in */
  .fade-in { animation: fadeIn 0.4s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 600px) {
    .keys-grid, .options-grid { grid-template-columns: 1fr; }
    .stats { grid-template-columns: repeat(2, 1fr); }
  }
</style>
</head>
<body>
<div class="wrap">

  <div class="header">
    <div class="logo-row">
      <div class="logo-icon"><span>V</span></div>
      <h1>The <em>Finder</em></h1>
    </div>
    <p class="tagline">Stock Footage &amp; Photo Scraper — Pexels + Pixabay</p>
  </div>

  <!-- Script Input -->
  <div class="section">
    <div class="section-label">Your YouTube Script</div>
    <textarea id="script" placeholder="Paste your full YouTube script here. Claude will read the context and extract the most visually relevant search keywords automatically..."></textarea>
  </div>

  <!-- API Keys -->
  <div class="section">
    <div class="section-label">API Keys</div>
    <div class="keys-grid">
      <div class="field">
        <label>Pexels API Key</label>
        <input type="text" id="pexels-key" value="ngjiKUE5JfXhuMi7C5ZLpr8zu1xqrYmu7CckyN0mh5fnVtcuhnbZSb0N" />
      </div>
      <div class="field">
        <label>Pixabay API Key</label>
        <input type="text" id="pixabay-key" value="55248891-5090da90850925c0705e24e94" />
      </div>
